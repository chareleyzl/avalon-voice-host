.app { width: 100%; max-width: 480px; margin: 0 auto; padding: 16px 0; }

.header { text-align: center; margin-bottom: 16px; }
.title { font-size: 1.4rem; color: #e8d5b7; letter-spacing: 2px; }

/* 人数选择 */
.num-select { display: flex; justify-content: flex-start; gap: 6px; flex-wrap: nowrap; padding: 0 4px; }
.num-btn {
  width: 40px; height: 40px; border-radius: 50%;
  border: 2px solid #3a3a5c;
  background: #1a1a2e; color: #e0e0e0;
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; flex-shrink: 0;
}
.num-btn.active { border-color: #e8d5b7; background: #e8d5b7; color: #1a1a2e; font-weight: bold; }

/* 角色表 */
.role-table { font-size: 0.9rem; }
.role-row { display: flex; padding: 4px 0; }
.role-row:first-child { margin-bottom: 2px; }
.role-side { width: 72px; flex-shrink: 0; font-size: 0.8rem; padding: 4px 0; }
.role-side.good { color: #5a8ecf; }
.role-side.evil { color: #c0392b; }
.role-tags { flex: 1; min-width: 0; }
.tag { display: inline-block; font-size: 0.78rem; padding: 2px 7px; border-radius: 8px; margin: 2px; }
.tag.good { background: rgba(90,142,207,.2); color: #5a8ecf; }
.tag.evil { background: rgba(192,57,43,.2); color: #c0392b; }

/* 选项 */
.options { margin-top: 12px; }
.option-item { display: flex; align-items: center; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #2a2a4a; }
.option-item:last-child { border-bottom: none; }
.option-label { font-size: 0.9rem; }
.option-desc { font-size: 0.72rem; color: #888; margin-top: 2px; }

/* 暂停时长 */
.pause-row { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; }
.pause-label { font-size: 0.8rem; color: #888; }
.stepper { display: flex; align-items: center; gap: 4px; }
.step-btn {
  width: 32px; height: 32px; border-radius: 8px;
  background: #3a3a5c; color: #e8d5b7;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; font-weight: bold;
}
.step-val {
  width: 48px; padding: 6px 0; border-radius: 6px;
  background: #1a1a2e; color: #e0e0e0;
  border: 1px solid #3a3a5c; font-size: 0.9rem; text-align: center;
}
.step-unit { font-size: 0.8rem; color: #888; }

/* 剧本预览 */
.script-section { padding: 10px 0; border-bottom: 1px solid #2a2a4a; }
.script-section:last-child { border-bottom: none; }
.script-head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.script-num {
  width: 26px; height: 26px; border-radius: 50%; background: #3a3a5c;
  color: #e8d5b7; display: flex; align-items: center; justify-content: center;
  font-size: 0.75rem; flex-shrink: 0;
}
.script-bold { font-weight: bold; font-size: 0.9rem; }
.script-body { padding-left: 34px; }
.script-line { padding: 2px 0; }
.script-sub { font-size: 0.78rem; color: #888; }
.script-pause { font-size: 0.75rem; color: #888; }

/* 游戏规则弹窗 */
.rules-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.7);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000;
}
.rules-modal {
  width: 86%; height: 80vh;
  background: #16213e; border-radius: 14px;
  border: 1px solid #3a3a5c;
  overflow: hidden;
  position: relative;
}
.rules-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 18px 10px;
  border-bottom: 1px solid #2a2a4a;
}
.rules-title { font-size: 1.15rem; color: #e8d5b7; font-weight: bold; }
.rules-close { font-size: 1.2rem; color: #888; padding: 0 4px; }
.rules-body {
  height: calc(80vh - 120px);
  padding: 12px 18px 24px;
  box-sizing: border-box;
}
.rules-footer {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 10px 18px 14px;
  background: #16213e;
  box-sizing: border-box;
}
.rules-confirm { width: 100%; margin: 0; }

.rules-section { margin-bottom: 14px; }
.rules-section:last-child { margin-bottom: 0; }
.rules-section-title {
  font-size: 0.92rem; color: #e8d5b7; font-weight: bold;
  margin-bottom: 6px; padding-bottom: 4px;
  border-bottom: 1px solid #2a2a4a;
}
.rules-subtitle { font-size: 0.85rem; font-weight: bold; margin: 8px 0 4px; }
.rules-subtitle.good { color: #5a8ecf; }
.rules-subtitle.evil { color: #c0392b; }
.rules-role { font-size: 0.8rem; padding: 2px 0; line-height: 1.5; }
.rules-role-name { color: #e0e0e0; font-weight: 500; }
.rules-role-desc { color: #aaa; }
.rules-text { font-size: 0.8rem; color: #bbb; padding: 2px 0; line-height: 1.6; }
.rules-bold { font-weight: bold; color: #e0e0e0; }
.rules-hl { color: #e8d5b7; font-weight: bold; }
