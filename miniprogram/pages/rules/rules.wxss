.app {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: #1a1a2e;
  color: #f6efe4;
}

.rules-section {
  margin: 24rpx 0;
  padding: 28rpx;
  border: 1rpx solid rgba(232, 213, 183, 0.22);
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.05);
}

.rules-section-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #f6efe4;
}

.rules-subtitle {
  margin: 18rpx 0 10rpx;
  font-size: 27rpx;
  font-weight: 700;
}

.good {
  color: #9ed8ff;
}

.evil {
  color: #ffb0a8;
}

.rules-text,
.rules-role {
  margin: 12rpx 0;
  font-size: 27rpx;
  line-height: 1.6;
  color: #ddd6ce;
}

.rules-role {
  display: flex;
  align-items: flex-start;
}

.rules-role-name {
  flex: 0 0 auto;
  font-weight: 700;
  color: #f6efe4;
}

.rules-role-desc {
  flex: 1;
  color: #ddd6ce;
}

.rules-bold {
  font-weight: 700;
  color: #f6efe4;
}

.rules-hl {
  color: #e8d5b7;
  font-weight: 700;
}

.rules-footer-action {
  width: 100%;
  margin-top: 28rpx;
  display: flex;
  justify-content: center;
  box-sizing: border-box;
}

.btn {
  width: 100%;
  margin: 0;
  padding: 0;
  min-height: 96rpx;
  box-sizing: border-box;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.rules-back-btn::after {
  border: 0;
}

.btn-primary {
  color: #1a1a2e;
  background: #e8d5b7;
}
